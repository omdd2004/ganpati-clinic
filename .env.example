# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin
ADMIN_PASSWORD=change-this-password

# Email notifications via Gmail SMTP (optional — booking works fine
# without these, but you won't get an email when a patient books)
GMAIL_USER=youraccount@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
ADMIN_EMAIL=whoevershouldgetalerts@anyemail.com

# WhatsApp notifications via Twilio Sandbox (optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+918530951675

# Site
NEXT_PUBLIC_SITE_URL=https://ganpatisonography.in
